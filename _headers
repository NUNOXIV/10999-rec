# Netlify _headers — Security baseline for 10999rec.com
# Applies to all routes

/*
  # HTTPS enforcement (browser will refuse HTTP for 1 year)
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

  # Clickjacking protection
  X-Frame-Options: SAMEORIGIN

  # MIME-sniffing protection
  X-Content-Type-Options: nosniff

  # Referrer policy — minimum data leak
  Referrer-Policy: strict-origin-when-cross-origin

  # Permissions Policy — disable APIs we don't use
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=(), usb=(), magnetometer=(), gyroscope=()

  # Content Security Policy — restricts where resources can come from
  # Allows: self + Google Fonts + click-to-load embeds (SoundCloud, Bandcamp)
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; frame-src https://w.soundcloud.com https://bandcamp.com; connect-src 'self'; base-uri 'self'; form-action 'self'; frame-ancestors 'self';

# Long cache for static assets
/*.jpg
  Cache-Control: public, max-age=31536000, immutable

/*.png
  Cache-Control: public, max-age=31536000, immutable

/*.webp
  Cache-Control: public, max-age=31536000, immutable
